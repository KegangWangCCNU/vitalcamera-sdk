{
  "name": "vitalcamera-sdk",
  "version": "0.6.8",
  "description": "Browser-based real-time physiological sensing SDK: heart rate, HRV, emotion, gaze, eye state, mouth/speaking, head pose",
  "type": "module",
  "main": "src/index.js",
  "module": "src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./adapter": "./src/adapter/browser.js",
    "./workers/*": "./src/workers/*"
  },
  "scripts": {
    "test": "node --test tests/**/*.test.js",
    "test:watch": "node --test --watch tests/**/*.test.js"
  },
  "peerDependencies": {
    "@litertjs/core": "^0.2.1",
    "@mediapipe/tasks-vision": "^0.10.21"
  },
  "peerDependenciesMeta": {
    "@litertjs/core": {
      "optional": true
    },
    "@mediapipe/tasks-vision": {
      "optional": true
    }
  },
  "files": [
    "src/",
    "models/",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "keywords": [
    "rppg",
    "heart-rate",
    "hrv",
    "emotion-recognition",
    "gaze-estimation",
    "head-pose",
    "mediapipe",
    "litert",
    "browser",
    "real-time",
    "physiological-sensing",
    "vital-camera",
    "webcam",
    "face-detection"
  ],
  "author": "Kegang Wang",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/KegangWangCCNU/vitalcamera-sdk.git"
  },
  "homepage": "https://github.com/KegangWangCCNU/vitalcamera-sdk#readme",
  "bugs": {
    "url": "https://github.com/KegangWangCCNU/vitalcamera-sdk/issues"
  }
}
